# Aviary — local development environment overrides.
#
# Copy this file to `.env` (docker compose loads it automatically). Every
# variable below is optional; sensible defaults live in docker-compose.yml.
# Uncomment only the lines you actually want to change.


# ══ Build-time package registries ═══════════════════════════════════════════
# Use these in corporate / air-gapped networks where pypi.org or
# registry.npmjs.org isn't reachable. Consumed by `docker compose build`
# and the helper scripts under scripts/.

# UV_INDEX_URL=https://artifactory.example.com/api/pypi/simple/
# NPM_CONFIG_REGISTRY=https://artifactory.example.com/api/npm/npm-remote/


# ══ Atlassian MCP servers ═══════════════════════════════════════════════════
# The Jira and Confluence MCP servers under mcp-servers/ each point at a
# single Atlassian site. Per-user API tokens are stored in Vault.

JIRA_BASE_URL=https://your-corp.atlassian.net
CONFLUENCE_BASE_URL=https://your-corp.atlassian.net


# ══ AWS Bedrock backend (optional) ══════════════════════════════════════════
# Only required if you route any model through AWS Bedrock in
# config/litellm/config.yaml.

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-2


# ══ LiteLLM proxy UI ════════════════════════════════════════════════════════
# Credentials default to admin / admin. Change for any non-loopback exposure.
# `LITELLM_SITE_PACKAGES` is only needed if the upstream LiteLLM image bumps
# its Python version and the patches in config/litellm/patches/ stop
# landing in the right site-packages directory.

# LITELLM_UI_USERNAME=admin
# LITELLM_UI_PASSWORD=admin
# LITELLM_SITE_PACKAGES=/usr/lib/python3.13/site-packages


# ══ Grafana ═════════════════════════════════════════════════════════════════

# GRAFANA_ADMIN_PASSWORD=admin


# ══ Workflow worker ═════════════════════════════════════════════════════════
# Shared secret between the workflow worker and the agent supervisor.
# Defaults to a well-known dev value — set something strong for any
# shared environment.

# WORKER_SHARED_SECRET=dev-worker-secret-change-me


# ══ Self-hosted vLLM via llama-swap (optional) ══════════════════════════════
# Only required if you wire up HuggingFace-gated models in scripts/llama-swap/.

# HF_TOKEN=hf_xxx


# ══ Deployment label ════════════════════════════════════════════════════════
# Surfaced by the API as the running environment name
# (development / staging / production).

# ENV=development
