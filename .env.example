# Aviary Phase 1 — local dev environment

# Package registries (for corporate/air-gapped environments)
#UV_INDEX_URL=https://artifactory.example.com/api/pypi/simple/
#NPM_CONFIG_REGISTRY=https://artifactory.example.com/api/npm/npm-remote/

# LLM backend (passed to runtime containers)
# Default: runtime → LiteLLM (docker) → llama-swap (host :9292) → llama-server (host)
#INFERENCE_ROUTER_URL=http://litellm:4000
#LITELLM_API_KEY=sk-aviary-dev
#LITELLM_MASTER_KEY=sk-aviary-dev
