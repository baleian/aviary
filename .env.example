# ══════════════════════════════════════════════════════════════════════
#  Aviary — single .env shared by both compose stacks.
#  `local-infra/.env` is a symlink to this file (created by setup-dev.sh).
#
#  Every line below is commented out — defaults are baked into compose.yml
#  and work out of the box. Uncomment a block to override.
# ══════════════════════════════════════════════════════════════════════


# ╔══════════════════════════════════════════════════════════════════╗
# ║ Aviary services (root compose)                                   ║
# ╚══════════════════════════════════════════════════════════════════╝


# ── Identity ──────────────────────────────────────────────────────────
#
# OIDC_ISSUER unset → no-IdP dev mode: every caller resolves to
# DEV_USER_SUB. With OIDC_ISSUER set, api + supervisor validate JWTs.
#
# Local Keycloak (provisioned by local-infra):
#   OIDC_ISSUER=http://localhost:8080/realms/aviary
#   OIDC_INTERNAL_ISSUER=http://host.docker.internal:8080/realms/aviary
#   OIDC_CLIENT_ID=aviary-web
#
# Hosted Auth0 / Okta (confidential client):
#   OIDC_ISSUER=https://<tenant>.us.auth0.com
#   OIDC_CLIENT_ID=<app-client-id>
#   OIDC_CLIENT_SECRET=<app-client-secret>

# DEV_USER_SUB=dev-user


# ── Inference & MCP gateways ──────────────────────────────────────────
#
# Unset LLM_GATEWAY_URL → direct mode (config.yaml `llm_backends`).
# Same for MCP_GATEWAY_URL → config.yaml `mcp_servers`.

# LLM_GATEWAY_URL=http://host.docker.internal:8090
# LLM_GATEWAY_API_KEY=sk-aviary-dev
# MCP_GATEWAY_URL=http://host.docker.internal:8090
# MCP_GATEWAY_API_KEY=sk-aviary-dev


# ── Vault ─────────────────────────────────────────────────────────────
#
# Both empty → fall back to config.yaml `secrets:` block.
# Both set → use Vault-backed per-user credentials.

# VAULT_ADDR=http://host.docker.internal:8200
# VAULT_TOKEN=dev-root-token


# ── Datastores ────────────────────────────────────────────────────────
#
# Postgres / Redis live in local-infra (started first). Service compose
# reaches them via host.docker.internal. Override for remote / managed.

# DATABASE_URL=postgresql+asyncpg://aviary:aviary@host.docker.internal:5432/aviary
# REDIS_URL=redis://host.docker.internal:6379/0


# ── Temporal ──────────────────────────────────────────────────────────
#
# Default points at the in-compose temporal container. Override for
# Temporal Cloud or a remote Temporal cluster.
#
# Temporal Cloud example:
#   TEMPORAL_HOST=<your-namespace>.tmprl.cloud:7233
#   TEMPORAL_NAMESPACE=<your-namespace>

# TEMPORAL_HOST=temporal:7233
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=aviary-workflows


# ── Runtime routing ───────────────────────────────────────────────────
#
# Default = in-compose runtime container. Point at the K3s NodePort
# (http://host.docker.internal:30300) to default agents into the K8s
# pool, or set agent.runtime_endpoint per-agent in the admin console.

# DEFAULT_RUNTIME_ENDPOINT=http://runtime:3000


# ── GitHub host override ──────────────────────────────────────────────
#
# Unset → github.com. Set to your Enterprise host to redirect `gh` / `git`
# inside agent sandboxes; the same per-user `github-token` is reused as
# the auth token. In K8s, see `runtime.githubHost` in the runtime chart.

# GITHUB_HOST=github.mycompany.com


# ── Internal service URLs ─────────────────────────────────────────────
#
# Defaults are compose service DNS — rarely need overriding.
# Browser-facing port: PROXY_PORT (service compose), LOCAL_DEPLOY_PROXY_PORT (K3s).

# SUPERVISOR_URL=http://supervisor:9000
# PROXY_PORT=3000
# LOCAL_DEPLOY_PROXY_PORT=80
# CORS_ORIGINS=["http://localhost:3000"]
# WORKER_SHARED_SECRET=dev-worker-secret-change-me
# COOKIE_SECURE=true


# ── Observability (OTel push) ─────────────────────────────────────────
#
# Disabled by default. Uncomment to push supervisor metrics to the
# local-infra OTel collector (Prometheus + Grafana auto-provisioned).

# OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318
# OTEL_SERVICE_NAME=aviary-supervisor


# ── Build / registry overrides ────────────────────────────────────────

# UV_INDEX_URL=https://artifactory.example.com/api/pypi/simple/
# NPM_CONFIG_REGISTRY=https://artifactory.example.com/api/npm/npm-remote/


# ╔══════════════════════════════════════════════════════════════════╗
# ║ Local-infra extras (opt-in services)                             ║
# ╚══════════════════════════════════════════════════════════════════╝


# ── Atlassian MCP servers ─────────────────────────────────────────────
#
# `cloud` (default) = REST v3 + ADF / Confluence v2.
# `legacy` = on-prem Server / Data Center.

# JIRA_BASE_URL=https://your-corp.atlassian.net
# CONFLUENCE_BASE_URL=https://your-corp.atlassian.net
# JIRA_API_VARIANT=cloud
# CONFLUENCE_API_VARIANT=cloud


# ── LiteLLM UI ────────────────────────────────────────────────────────

# LITELLM_UI_USERNAME=admin
# LITELLM_UI_PASSWORD=admin
# LITELLM_SITE_PACKAGES=/usr/lib/python3.13/site-packages


# ── Grafana ───────────────────────────────────────────────────────────

# GRAFANA_ADMIN_PASSWORD=admin


# ── HuggingFace ───────────────────────────────────────────────────────

# HF_TOKEN=hf_...
